# Oracle Brain v6.0.0 — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-64-char-string

# ── Groq API Keys (at least one required) ─────────────────────────────────────
GROQ_KEY_1=gsk_your_key_here
GROQ_KEY_2=
GROQ_KEY_3=

# ── Anthropic (optional fallback) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Google OAuth (required for Google login) ──────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ── PostgreSQL (optional — falls back to JSON files) ──────────────────────────
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# ── Redis (optional — falls back to in-memory rate limiting) ─────────────────
# Format: redis://localhost:6379/0
REDIS_URL=

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_PER_MINUTE=20
RATE_PER_HOUR=200
RATE_PER_DAY=1000
RATE_LIMIT_ENABLED=true

# ── Render port (set automatically by Render) ────────────────────────────────
PORT=5000
