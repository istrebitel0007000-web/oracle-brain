# ─────────────────────────────────────────────────────────────
# Oracle Brain v5.5 — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Django
DJANGO_SECRET_KEY=your-very-long-random-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-render-domain.onrender.com

# PostgreSQL (Render provides these automatically)
DB_NAME=oracle_brain
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Groq API Keys (add up to 3 for key rotation)
GROQ_KEY_1=gsk_your_first_groq_key_here
GROQ_KEY_2=gsk_your_second_groq_key_here
GROQ_KEY_3=gsk_your_third_groq_key_here

# Oracle Brain Model Config
ORACLE_MODEL=deepseek-r1-distill-llama-70b
ORACLE_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
ORACLE_MAX_TOKENS=4096
ORACLE_TEMPERATURE=0.7

# Daily budget limit in USD (0.0 = disabled)
DAILY_BUDGET_USD=0.0

# Ollama fallback (optional local model)
OLLAMA_ENABLED=False
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Web Auth (optional basic auth for web UI)
WEB_AUTH_USER=
WEB_AUTH_PASS=

# Backup encryption password (optional)
BACKUP_PASSWORD=
